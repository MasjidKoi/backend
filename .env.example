# Copy to .env — never commit .env to version control

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# Public URL of the API — baked into the frontend bundle at build time.
# On a server, set this to your server's public IP or domain.
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=masjidkoi
POSTGRES_PASSWORD=masjidkoi
POSTGRES_DB=masjidkoi

# FastAPI connects via PgBouncer (transaction pool mode)
DATABASE_URL=postgresql+asyncpg://masjidkoi:masjidkoi@pgbouncer:6432/masjidkoi

# Direct connection for Alembic migrations (bypasses pgbouncer)
# Run migrations inside the api container: docker compose exec api uv run alembic upgrade head
DATABASE_URL_SYNC=postgresql://masjidkoi:masjidkoi@postgres:5432/masjidkoi

# ── GoTrue (Auth) ─────────────────────────────────────────────────────────────
# Must be a strong random string — shared between GoTrue and FastAPI.
# Generate: openssl rand -base64 32
GOTRUE_JWT_SECRET=change-me-use-openssl-rand-base64-32

# Service role JWT — generated by: uv run python scripts/gen_service_token.py
# Run that script AFTER setting GOTRUE_JWT_SECRET above.
GOTRUE_SERVICE_ROLE_KEY=

# GoTrue base URL (container-to-container; default works with docker compose)
GOTRUE_URL=http://gotrue:9999

# Public URL of GoTrue (used in email links sent to users)
GOTRUE_EXTERNAL_URL=http://localhost:9999

# Frontend URL (for redirect after email confirmation / password reset)
FRONTEND_URL=http://localhost:3000
GOTRUE_URI_ALLOW_LIST=http://localhost:3000

# ── Email (leave blank for dev — GOTRUE_MAILER_AUTOCONFIRM=true skips SMTP) ──
GOTRUE_MAILER_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@masjidkoi.com
