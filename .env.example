# Copy to .env and fill in values
# Never commit .env to version control

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=masjidkoi
POSTGRES_PASSWORD=masjidkoi
POSTGRES_DB=masjidkoi

# FastAPI connects via PgBouncer (transaction pool mode)
DATABASE_URL=postgresql+asyncpg://masjidkoi:masjidkoi@pgbouncer:6432/masjidkoi

# Direct connection for Alembic migrations (bypasses pgbouncer)
DATABASE_URL_SYNC=postgresql://masjidkoi:masjidkoi@localhost:5432/masjidkoi
